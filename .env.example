# Toggle the backend solver mock.
#   True  — short-circuits both ILP and FFD (returns docs/mockPlan.json).
#           Default for native development without a Gurobi licence.
#   False — runs real Gurobi/FFD. Required for the live demo and benchmarks.
# NOTE: docker-compose.yml hardcodes False on the backend and celery services,
# so the Docker stack always uses the real solver regardless of this value.
USE_MOCK_SOLVER=True
SOLVER_THRESHOLD=20
REDIS_URL=redis://localhost:6379
DATABASE_URL=postgresql://localhost/flow3d

# Absolute path to your Gurobi WLS academic license. Read by docker-compose
# and mounted into the backend + celery containers at /opt/gurobi/gurobi.lic.
# Windows: GUROBI_LICENSE_PATH=C:/Users/<you>/gurobi.lic
# macOS:   GUROBI_LICENSE_PATH=/Users/<you>/gurobi.lic
GUROBI_LICENSE_PATH=

# Gurobi tuning knobs — leave blank to keep Gurobi defaults.
# GUROBI_TIME_LIMIT is in seconds; GUROBI_MIP_GAP is the relative MIP gap
# (e.g. 0.0001 for 0.01%). GUROBI_OUTPUT_FLAG=0 suppresses console logging
# (default), 1 prints the full Gurobi log — useful when tuning the model.
GUROBI_TIME_LIMIT=
GUROBI_MIP_GAP=
GUROBI_THREADS=
GUROBI_OUTPUT_FLAG=0
